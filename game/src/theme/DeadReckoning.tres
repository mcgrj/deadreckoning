[resource]
# Default font for all UI — Cinzel for headers and interactive labels.
# Override per node type below using the Godot Theme editor.
#
# Per-type overrides to add in the Theme editor (Project → Open Theme Editor):
#   Label          → Fonts/font = CrimsonPro-Regular, Font Sizes/font_size = 22
#   RichTextLabel  → Fonts/normal_font = CrimsonPro-Regular, italic_font = CrimsonPro-Italic, Font Sizes/normal_font_size = 22
#   Button         → Fonts/font = Cinzel-Regular, Font Sizes/font_size = 20
#
# Size constants are in game/src/constants/FontSizes.gd
default_font = ExtResource("1_cinzel")
default_font_size = 20
